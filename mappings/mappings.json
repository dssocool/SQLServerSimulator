{
  "mappings": [
    {
      "statement": "SELECT Id, Name, Price FROM Products",
      "csvFile": "products.csv",
      "columns": [
        { "name": "Id", "type": "int" },
        { "name": "Name", "type": "nvarchar(50)" },
        { "name": "Price", "type": "decimal(10,2)" }
      ]
    },
    {
      "sqlFile": "products.sql",
      "csvFile": "products.csv",
      "columns": [
        { "name": "Id", "type": "int" },
        { "name": "Name", "type": "nvarchar(50)" },
        { "name": "Price", "type": "decimal(10,2)" }
      ]
    },
    {
      "statementPattern": "from\\s+\\[?sys\\]?\\.\\[?databases\\]?",
      "csvFile": "databases.csv",
      "columns": [
        { "name": "Name", "type": "nvarchar(128)" }
      ]
    },
    {
      "statementPattern": "from\\s+\\[?INFORMATION_SCHEMA\\]?\\.\\[?TABLES\\]?|join\\s+\\[?sys\\]?\\.\\[?schemas\\]?",
      "csvFile": "tables.csv",
      "columns": [
        { "name": "TABLE_CATALOG", "type": "nvarchar(128)" },
        { "name": "TABLE_SCHEMA", "type": "nvarchar(128)" },
        { "name": "TABLE_NAME", "type": "nvarchar(128)" },
        { "name": "TABLE_TYPE", "type": "nvarchar(32)" }
      ]
    }
  ]
}
